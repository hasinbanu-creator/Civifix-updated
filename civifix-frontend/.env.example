# CiviFix Frontend Mobile App - Environment Configuration

# API Base URL - Update this with your backend server URL
EXPO_PUBLIC_API_URL=http://localhost:8000:8000/api/v1

# App Configuration
EXPO_PUBLIC_APP_NAME=CiviFix
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags (optional)
EXPO_PUBLIC_ENABLE_DEBUG=true
EXPO_PUBLIC_OFFLINE_MODE=false
